# Backend
BACKEND_BIND_IP=127.0.0.1
BACKEND_PORT=8000
POSTGRES_BIND_IP=127.0.0.1
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=jobby
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/jobby
COMPOSE_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/jobby

# Hermes AI gateway
HERMES_BASE_URL=http://localhost:8010
HERMES_SERVICE_TOKEN=local-dev-token
HERMES_PROVIDER=
HERMES_MODEL=
HERMES_TIMEOUT_SECONDS=180

# Shared auth-backed Gmail integration
AUTH_BASE_URL=https://auth.dimy.dev
AUTH_SERVICE_TOKEN=
FRONTEND_BASE_URL=http://localhost:3000
GMAIL_SYNC_RECENT_THREADS=25
GMAIL_SYNC_SEARCH_PER_APPLICATION=10

# Frontend
FRONTEND_BIND_IP=127.0.0.1
